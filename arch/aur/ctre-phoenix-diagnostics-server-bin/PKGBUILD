# -*- mode: bash-ts -*-
pkgname=ctre-phoenix-diagnostics-server-bin
pkgdesc="CLI Utility that allows Phoenix Tuner to manage CTR Electronics devices"
# _binname=${pkgname%ctre-}
_binname=PhoenixDiagnosticsProgram
provides=("ctre-phoenix-diagnostics-server")

pkgrel=1
arch=('x86_64' 'aarch64')
license=('None') # can't easily find this
url="https://docs.ctr-electronics.com/cli-tools"

pkgver="26.1.3"
source_x86_64=("https://redist.ctr-electronics.com/tools/PhoenixDiagnosticsProgram/26.1.3/PhoenixDiagnosticsProgram-26.1.3-linuxx86-64")
sha1sums_x86_64=("b85141bbc02ff20d22d52eecb6b58c0494cd485b")
source_aarch64=("https://redist.ctr-electronics.com/tools/PhoenixDiagnosticsProgram/26.1.3/PhoenixDiagnosticsProgram-26.1.3-linuxarm64")
sha1sums_aarch64=("031830b582f8c459b28ca051e4dd2d078893087b")

depends=()
noextract=(
    ${source_x86_64[@]}
    ${source_aarch64[@]}
)
package() {
    cd "$srcdir"
    case "$arch" in
       x86_64) _binfile="${_binname}-${pkgver}-linuxx86-64" ;;
       aarch64) _binfile="${_binname}-${pkgver}-linuxarm64" ;;
    esac
    mv "${_binfile}" "${_binname}"
    # TODO: ln -sf "${_binfile}" "${_binname}" and move both?
    install -Dm0755 -t "$pkgdir/usr/bin" "$srcdir/${_binname}"
}
