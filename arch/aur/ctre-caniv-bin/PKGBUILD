# -*- mode: bash-ts -*-
pkgname=ctre-caniv-bin
pkgdesc="CLI Utility to enumerate, retrieve info and configure CANivore devices"
# _binname=${pkgname%ctre-}
_binname=caniv
provides=("ctre-caniv")

pkgrel=1
arch=('x86_64' 'aarch64')
license=('None') # can't easily find this
url="https://docs.ctr-electronics.com/cli-tools"

pkgver="1.1.1.0"
source_x86_64=("https://redist.ctr-electronics.com/tools/caniv/1.1.1.0/caniv-1.1.1.0-linuxx86-64")
sha1sums_x86_64=("26ea28e8e99261cfb35822daf091f47910383e92")
source_aarch64=("https://redist.ctr-electronics.com/tools/caniv/1.1.1.0/caniv-1.1.1.0-linuxarm64")
sha1sums_aarch64=("e4a98c618735ba08ab5cb54501e3ffd3c381b79b")

depends=()
noextract=(
    ${source_x86_64[@]}
    ${source_aarch64[@]}
)

package() {
    cd "$srcdir"
    case "$arch" in
       x86_64) _binfile="${_binname}-${pkgver}-linuxx86-64" ;;
       aarch64) _binfile="${_binname}-${pkgver}-linuxarm64" ;;
    esac
    mv "${_binfile}" "${_binname}"
    # TODO: ln -sf "${_binfile}" "${_binname}" and move both?
    install -Dm0755 -t "$pkgdir/usr/bin" "$srcdir/${_binname}"
}
