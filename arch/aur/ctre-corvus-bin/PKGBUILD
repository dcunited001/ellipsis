# -*- mode: bash-ts -*-
pkgname=ctre-corvus-bin
pkgdesc="CLI Utility to generate mechanisms"
# _binname=${pkgname%ctre-}
_binname=corvus
provides=("ctre-corvus")

pkgrel=1
arch=('x86_64' 'aarch64')
license=('None') # can't easily find this
url="https://docs.ctr-electronics.com/cli-tools"

pkgver="26.1.1"
source_x86_64=("https://redist.ctr-electronics.com/tools/corvus/26.1.1/corvus-26.1.1-linuxx86-64")
sha1sums_x86_64=("70f9b09315f89881af357531aa64a75daf0bb150")
source_aarch64=("https://redist.ctr-electronics.com/tools/corvus/26.1.1/corvus-26.1.1-linuxarm64")
sha1sums_aarch64=("2625e9bc339a08e18fae2e249ebfcbe351e5297c")

depends=()
noextract=(
    ${source_x86_64[@]}
    ${source_aarch64[@]}
)

package() {
    cd "$srcdir"
    case "$arch" in
       x86_64) _binfile="${_binname}-${pkgver}-linuxx86-64" ;;
       aarch64) _binfile="${_binname}-${pkgver}-linuxarm64" ;;
    esac
    mv "${_binfile}" "${_binname}"
    # TODO: ln -sf "${_binfile}" "${_binname}" and move both?
    install -Dm0755 -t "$pkgdir/usr/bin" "$srcdir/${_binname}"
}
