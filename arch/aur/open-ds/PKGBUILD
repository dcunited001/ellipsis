# -*- mode: bash-ts -*-

pkgname=open-ds
pkgver=0.3.1
pkgrel=1
pkgdesc="A reverse-engineered lightweight cross-platform FRC Driver Station"
arch=('x86_64' 'aarch64')
license=('BSD-4-Clause')
url="https://boomaa23.github.io/open-ds"
provides=('open-ds')
conflicts=('open-ds-bin')

depends=(
    'java-runtime>=17'
    # also X11 deps, including libXt
)
makedepends=(
    'maven'
    'java-environment>=8'
    'base-devel'
    'gcc'
    'make'
    'linux-headers'
    'wget'
)

source=(
    "https://github.com/Boomaa23/open-ds/archive/refs/tags/v${pkgver}.tar.gz"
)
sha256sums=(
    '9c3658a6f4e32fc30fa57c4079137b3eb4897d05d8ac5bb9a75dc044e8f26c63'
)

verify() {
    echo "TODO: verify GPG signature on JAR"
}

prepare() {
    cd "$srcdir/$pkgname-$pkgver"
    make clean
}

build() {
    cd "$srcdir/$pkgname-$pkgver"
    # JAVA_HOME=/usr/lib/jvm/default make native-linux
    UNIX_JDK_INCLUDE_PATH=/usr/lib/jvm/default/include make native-linux
    make check
    make build
}

package() {
    install -Dm0755 -t "$pkgdir/usr/bin/" "$srcdir/../open-ds"

    cd "$srcdir/$pkgname-$pkgver"

    __pkgver=0.3.2-SNAPSHOT

    install -Dm644 LICENSE.txt -t "${pkgdir}/usr/share/licenses/${pkgname}/"

    # install -Dm0644 -t "$pkgdir/usr/share/java/$pkgname/" "target/libJNativeHook-v${pkgver}.x86_64.so"
    # install -Dm0644 -t "$pkgdir/usr/share/java/$pkgname/" "target/original-open-ds-v${pkgver}.jar"

    install -Dm0644 -t "$pkgdir/usr/share/java/${pkgname}/" "target/${pkgname}-v${__pkgver}.jar"
    install -Dm0644 -t "$pkgdir/usr/share/java/${pkgname}/" "target/${pkgname}-v${__pkgver}-jar-with-dependencies.jar"
    ln -sf "open-ds-v${__pkgver}-jar-with-dependencies.jar" "$pkgdir/usr/share/java/${pkgname}/${pkgname}.jar"
}
