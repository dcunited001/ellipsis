    echo "TODO: verify GPG signature on JAR"
}

package() {
    # TODO: already in $srcdir. this seems non-hermetic
    install -Dm0755 -t "$pkgdir/usr/bin/" "$srcdir/../open-ds"

    cd "$srcdir"

    # TODO: fetch license: install -Dm644 LICENSE.txt -t "${pkgdir}/usr/share/licenses/${pkgname}/"
    install -Dm0644 -t "$pkgdir/usr/share/java/${_pkgname}/" "${_pkgname}-v${pkgver}.jar"

    # necessary until i figured out that makepkg was extracting the JAR
    #
    # ln -sf "${_pkgname}-v${pkgver}.jar" "$pkgdir/usr/share/java/${_pkgname}/${_pkgname}.jar"
    #
    # if [[ "$arch" != "aarch64" ]]; then
    #   _arch="amd64"
    # else
    #   _arch="aarch64"
    # fi
    #
    # install -Dm0644 -t "$pkgdir/usr/share/java/${_pkgname}/" "opends-lib-linux-${_arch}.so"
}
