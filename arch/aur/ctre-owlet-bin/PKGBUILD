# -*- mode: bash-ts -*-
pkgname=ctre-owlet-bin
pkgdesc="CLI Utility to convert CTR Electronics hoot .hoot files into other logging formats"
# _binname=${pkgname%ctre-}
_binname=owlet
provides=("ctre-owlet")

pkgrel=1
arch=('x86_64' 'aarch64')
license=('None') # can't easily find this
url="https://docs.ctr-electronics.com/cli-tools"

pkgver="26.1.0"
source_x86_64=("https://redist.ctr-electronics.com/tools/owlet/26.1.0/owlet-26.1.0-linuxx86-64")
sha1sums_x86_64=("fae8464ed63db8926e954af59ee5fcd49598b522")
source_aarch64=("https://redist.ctr-electronics.com/tools/owlet/26.1.0/owlet-26.1.0-linuxarm64")
sha1sums_aarch64=("ddc2d5fa2bf3982ecffa6fcb07cb3668f5562eed")

depends=()
noextract=(
    ${source_x86_64[@]}
    ${source_aarch64[@]}
)

package() {
    cd "$srcdir"
    case "$arch" in
       x86_64) _binfile="${_binname}-${pkgver}-linuxx86-64" ;;
       aarch64) _binfile="${_binname}-${pkgver}-linuxarm64" ;;
    esac
    mv "${_binfile}" "${_binname}"
    # TODO: ln -sf "${_binfile}" "${_binname}" and move both?
    install -Dm0755 -t "$pkgdir/usr/bin" "$srcdir/${_binname}"
}
